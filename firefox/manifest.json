{
  "manifest_version": 2,
  "name": "Hide Wiki",
  "version": "1.0.0",
  "description": "Blendet Wikipedia/Britannica-Kontextboxen auf YouTube aus.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hide-wiki@hidewiki.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
