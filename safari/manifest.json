{
  "manifest_version": 3,
  "name": "Hide Wiki",
  "version": "1.0.0",
  "description": "Blendet Wikipedia/Britannica-Kontextboxen auf YouTube aus.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
